{
  "name": "amr-toolkit",
  "version": "1.0.1",
  "description": "amr 音频录制与播放（微信语音所用的格式）",
  "main": "BenzAMRRecorder.cjs.js",
  "module": "BenzAMRRecorder.esm.js",
  "exports": {
    ".": {
      "import": "./BenzAMRRecorder.esm.js",
      "require": "./BenzAMRRecorder.cjs.js",
      "default": "./BenzAMRRecorder.esm.js"
    }
  },
  "types": "BenzAMRRecorder.d.ts",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "build": "rollup -c"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rocwong-cn/amr-toolkit.git"
  },
  "keywords": [
    "amr",
    "Web Audio API",
    "record",
    "userMedia",
    "silk-v3"
  ],
  "author": "rocwong-cn",
  "license": "MIT",
      "bugs": {
        "url": "https://github.com/rocwong-cn/amr-toolkit/issues"
  },
  "homepage": "https://github.com/rocwong-cn/amr-toolkit#readme",
  "devDependencies": {
    "@babel/core": "^7.2.2",
    "@babel/plugin-external-helpers": "^7.2.0",
    "@babel/plugin-proposal-class-properties": "^7.2.3",
    "@babel/preset-env": "^7.2.3",
    "@babel/preset-stage-0": "^7.0.0",
    "rollup": "^1.0.0",
    "rollup-plugin-babel": "^4.2.0",
    "rollup-plugin-commonjs": "^9.1.3",
    "rollup-plugin-node-resolve": "^4.0.0",
    "rollup-plugin-re": "^1.0.7",
    "rollup-plugin-sourcemaps": "^0.4.2",
    "rollup-plugin-terser": "^4.0.0"
  },
  "dependencies": {
    "benz-recorderjs": "^1.0.5"
  }
}
